# Copy to `.env` and adjust. Shell exports override these values (python-dotenv).
# See SERVER.md for nginx and Podman layout.

### MySQL (Database/queries, migrations)
DB_HOST=localhost
DB_PORT=3306
DB_USER=netflower
DB_PASSWORD=change_me
DB_NAME=netflower

### JWT / auth (Server/security, Server/api)
JWT_SECRET=change_this_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

### Main API + WebSockets (python -m Server.api; `python -m Server` runs api+frontend+webgl)
AUTH_SERVER_HOST=0.0.0.0
AUTH_SERVER_PORT=8000
# Production behind nginx:
# API_PREFIX=/api
# WS_PREFIX=/ws

### Dev / process supervision (Server/__main__.py)
UVICORN_RELOAD=1
SERVER_SUPERVISE=0
WATCHDOG_INTERVAL_SEC=15
WATCHDOG_FAIL_THRESHOLD=3
WATCHDOG_STARTUP_GRACE_SEC=12

### Logging (logging_config, frontend, webgl)
# LOG_DIR=logs
PYTHON_STREAM_TEE=1

### Static frontend proxy (python -m Server.frontend)
FRONTEND_PORT=3000
AUTH_BACKEND=http://localhost:8000
AUTH_STRIP_API_PREFIX=1

### Unity WebGL static (python -m Server.webgl)
# WEBGL_ROOT=/srv/CSDS-Final-Project/Builds/Netflower
WEBGL_PORT=3001
WEBGL_HOST=localhost
