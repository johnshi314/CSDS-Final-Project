  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharDisplayInfo
  char_name: Linden
  internal_name: Main
  char_desc: "Our new consultant! A defensive unit with good movement and high damage
    potential.\r\n "
  char_id: 1
  char_icon: {fileID: 0}
  colors: {r: 0.3529412, g: 0.8392157, b: 0.3137255, a: 1}
  movement: 5
  characterunlocked: 0
  ability_name: []
  ability_desc:
  - '

    1 range, 1 target, 4 damage, on hit: gain 1 Will (max 10)


    Will:
    Used for certain abilities, does not expire.

'
  - "2 range, all targets in range, 2 damage, on 1 or more target hit: gain 2 movement
    and 1 Will \r\n"
  - "Cooldown 3; spend all Will, gain Shield equal to Will, gain movement equal to
    Will/2 rounded down.\r\nShield: While this unit has >0 Shield, when this unit
    takes damage, Shield is reduced instead of hp. Expires when this unit\u2019s
    turn starts.\r\n"
  - "Cooldown 3; 2 range, all targets in range, at start of next turn gain 2 Power
    up for each enemy in range \r\n\tPower up X: This unit\u2019s attacks deal X
    more damage. Expires at end of turn"
  ability_icons: []
